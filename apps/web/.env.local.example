# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key

# Resend (email)
RESEND_API_KEY=your-resend-key
EMAIL_FROM="YoBoss <hello@yourdomain.com>"
EMAIL_UNSUB_SECRET=replace-with-random-32+chars
# Where in-app feedback submissions are emailed. Optional — without it
# feedback is still saved to the `feedback` table, just no email digest.
FEEDBACK_NOTIFY_EMAIL=you@yourdomain.com
# Comma-separated email allowlist for /admin/* pages. Anyone not in the
# list gets a 404 on those routes.
ADMIN_EMAILS=you@yourdomain.com

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Upstash Redis — per-user per-minute rate limiting on AI routes.
# Without these, the per-minute limiter in src/lib/ai/rate-limit.ts is
# silently disabled and only the monthly-allowance check remains, so a
# runaway client can blast Anthropic faster than billing can debit.
# Free tier at https://upstash.com is plenty. Use the REST API URL/token
# (not the redis:// protocol values).
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Meta Pixel — only loads after the user accepts cookies in the consent
# banner. Leave empty to disable Pixel entirely. Get the ID from
# Events Manager: https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=
